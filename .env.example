# Required for the chatbot (src/app/api/chat/route.js).
ANTHROPIC_API_KEY=

# Required for the Resources video/quiz feature (src/lib/supabase/client.js).
# Project Settings -> API in the Supabase dashboard.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Required for the Donate page (src/components/Donate.jsx) to show a real
# button instead of "coming soon". A Stripe Payment Link (or similar
# hosted "customer chooses price" link) works well for pay-as-you-can.
NEXT_PUBLIC_DONATION_LINK=
